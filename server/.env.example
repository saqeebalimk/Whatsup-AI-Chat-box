PORT=3000
NODE_ENV=development

# ─── WhatsApp Meta Cloud API ─────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v19.0

# Staff WhatsApp number to receive alerts (with country code, no +)
STAFF_WHATSAPP_NUMBER=919876543210

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=./config/google-service-account.json

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
ADMIN_SECRET=change_this_to_a_strong_secret_password

# ─── Email Notifications (optional) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
STAFF_EMAIL=reception@parksidemedical.com

# ─── Clinic Info ──────────────────────────────────────────────────────────────
CLINIC_NAME=Parkside Medical Center
CLINIC_PHONE=+91-XXXXXXXXXX
EMERGENCY_NUMBER=+91-XXXXXXXXXX
